@model ExampleThaiBevApp.Models.User

@{
    ViewData["Title"] = "Login";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-4 mx-auto text-center">
            <h1 class="display-4">Login</h1>
            <hr />
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mx-auto">
            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label class="form-label">Username</label>
                    <input name="Username" class="form-control" placeholder="Enter username" />
                </div>

                <div class="form-group mb-3">
                    <label class="form-label">Password</label>
                    <input type="password" name="Password" class="form-control" placeholder="Enter password" />
                </div>

                <div class="form-group mb-3">
                    <button type="submit" class="btn btn-primary w-100">ลงชื่อเข้าใช้</button>
                </div>

                <div class="text-center">
                    <a asp-action="Register">สมัครสมาชิก</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}